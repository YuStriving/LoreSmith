# =============================================================================
# LoreSmith 项目环境变量配置模板
# =============================================================================
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件不应提交到 Git 仓库（已在 .gitignore 中排除）

# =============================================================================
# Python Internal API 配置
# =============================================================================
# API 服务主机地址
AINOVEL_INTERNAL_API_HOST=127.0.0.1

# API 服务端口
AINOVEL_INTERNAL_API_PORT=8000

# 内部接口认证 Token（用于接口安全校验）
AINOVEL_INTERNAL_API_TOKEN=your-secret-token-here

# 运行记录持久化文件路径
AINOVEL_INTERNAL_API_REGISTRY=output/internal_api/runs.json

# =============================================================================
# LLM Provider 配置
# =============================================================================
# 主要 Provider（可选：openai, openrouter, anthropic, deepseek, qwen等）
AINOVEL_PROVIDER=openai

# 主要模型名称
AINOVEL_MODEL=gpt-4o-mini

# OpenAI 配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter 配置（如果使用 OpenRouter）
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Anthropic 配置（如果使用 Claude）
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DeepSeek 配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen 配置
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# =============================================================================
# HTTP 客户端配置
# =============================================================================
# 单次请求超时时间（秒）
AINOVEL_HTTP_TIMEOUT=60

# 流式请求总超时时间（秒）
AINOVEL_STREAM_TOTAL_TIMEOUT=300

# =============================================================================
# Java Platform 配置（Spring Boot）
# =============================================================================
# 数据库配置（MySQL）
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ainovel?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=ainovel
SPRING_DATASOURCE_PASSWORD=ainovel

# Spring Boot 服务端口
SERVER_PORT=8080

# =============================================================================
# 前端配置（Vite）
# =============================================================================
# 前端开发服务器端口
VITE_PORT=5173

# API 代理配置（开发环境）
VITE_API_PROXY_TARGET=http://127.0.0.1:8080
VITE_INTERNAL_PROXY_TARGET=http://127.0.0.1:8000

# =============================================================================
# Docker 配置
# =============================================================================
# MySQL 配置
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=ainovel
MYSQL_USER=ainovel
MYSQL_PASSWORD=ainovel
MYSQL_PORT=3306

# =============================================================================
# 测试配置
# =============================================================================
# 测试用的 API Key（仅用于测试环境）
TEST_API_KEY=test-api-key-for-testing

# 测试输出目录
TEST_OUTPUT_DIR=output/test

# =============================================================================
# 日志配置
# =============================================================================
# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=output/logs/ainovel.log

# =============================================================================
# 其他配置
# =============================================================================
# 上下文窗口大小（token数量）
AINOVEL_CONTEXT_WINDOW=128000

# 默认写作风格
AINOVEL_DEFAULT_STYLE=default

# 最大章节数（用于测试或限制）
AINOVEL_MAX_CHAPTERS=100